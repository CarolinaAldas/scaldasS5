<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="scaldasS5.Views.vPersona"
             Title="vPersona">

    <VerticalStackLayout Padding="20" Spacing="10">

        <Label Text="CRUD EN SQLITE: Persona"
               FontSize="20"
               TextColor="Blue"
               HorizontalOptions="Center" />

        <Entry x:Name="txtName"
               Placeholder="Ingresa el nombre" />

        <!-- Botones en fila separada -->
        <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
            <Button Grid.Column="0"
                    Text="Agregar persona"
                    BackgroundColor="#9B59B6"
                    TextColor="White"
                    Clicked="btnInsertar_Clicked" />

            <Button Grid.Column="1"
                    Text="Listar personas"
                    BackgroundColor="#9B59B6"
                    TextColor="White"
                    Clicked="btnListar_Clicked" />
        </Grid>

        <CollectionView x:Name="listaPersonas">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid ColumnDefinitions="40,*,Auto,Auto" Padding="5" ColumnSpacing="8">
                        <Label Grid.Column="0"
                       Text="{Binding Id}"
                       VerticalOptions="Center" />
                        <Label Grid.Column="1"
                       Text="{Binding Name}"
                       VerticalOptions="Center" />
                        <Button Grid.Column="2"
                        Text="Editar"
                        BackgroundColor="#2ECC71"
                        TextColor="White"
                        Margin="0,0,4,0"
                        CommandParameter="{Binding .}"
                        Clicked="btnEditar_Clicked" />
                        <Button Grid.Column="3"
                        Text="Eliminar"
                        BackgroundColor="#E74C3C"
                        TextColor="White"
                        CommandParameter="{Binding .}"
                        Clicked="btnEliminar_Clicked" />
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </VerticalStackLayout>
</ContentPage>